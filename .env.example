# Copy to .env and adjust. Docker Compose reads this file for the web/notifier services.

# --- Core ---
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=activities.example.com
CSRF_TRUSTED_ORIGINS=https://activities.example.com
SITE_ADDRESS=activities.example.com
TIME_ZONE=Europe/Malta

# Database password used by the db container AND the app connection string
POSTGRES_PASSWORD=change-me

# --- Email (SMTP) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=notifications@example.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=School Activities <notifications@example.com>

# --- WhatsApp (Meta Cloud API) ---
# Leave WHATSAPP_ENABLED=false to log WhatsApp messages instead of sending.
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0

# --- Notifier worker ---
NOTIFIER_BATCH_SIZE=20
NOTIFIER_MAX_ATTEMPTS=5
