{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Django (docker, DEBUGPY=1)",
            "type": "debugpy",
            "request": "attach",
            "connect": { "host": "localhost", "port": 5678 },
            "pathMappings": [
                { "localRoot": "${workspaceFolder}", "remoteRoot": "/app" }
            ],
            "django": true,
            "justMyCode": true
        }
    ]
}
